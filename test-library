					Dropdown.Toggled = not Dropdown.Toggled
					if Dropdown.Toggled then
						divLine.Visible = true
						optHolder.Visible = true
						tween(chevron, 0.2, {Rotation = 180, ImageColor3 = Color3.fromRGB(80, 160, 255)})
						tween(dropStroke, 0.2, {Color = Color3.fromRGB(60, 130, 220)})
					else
						tween(chevron, 0.2, {Rotation = 0, ImageColor3 = Color3.fromRGB(90, 90, 105)})
						tween(dropStroke, 0.2, {Color = Color3.fromRGB(45, 45, 52)})
						task.delay(0.18, function()
							if not Dropdown.Toggled then
								optHolder.Visible = false
								divLine.Visible = false
							end
						end)
					end
				end

