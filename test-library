		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local screenSize = arizon.AbsoluteSize
			local fx = math.clamp(input.Position.X - dragOffset.X, 0, screenSize.X - main.AbsoluteSize.X)
			local fy = math.clamp(input.Position.Y - dragOffset.Y, 0, screenSize.Y - main.AbsoluteSize.Y)
