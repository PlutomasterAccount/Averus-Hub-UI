							task.delay(0.12, function()
								tween(optBtn, 0.15, {BackgroundColor3 = Color3.fromRGB(26, 26, 30)})
							end)
							ToggleDrop()
							callback(Dropdown.Value)
						end)
					end
				end

				function Dropdown:Refresh(opts, del)
					if del then
						for _, v in pairs(optHolder:GetChildren()) do
							if v:IsA("TextButton") then
								v:Destroy()
							end
						end
					end
					Dropdown.Options = opts
					AddOptions(opts)
				end

				function Dropdown:Set(val)
					Dropdown.Value = val
					dropTitle.Text = text .. " — " .. tostring(val)
					callback(Dropdown.Value)
				end

				dropHeader.MouseEnter:Connect(function()
					tween(dropFrame, 0.18, {BackgroundColor3 = Color3.fromRGB(34, 34, 38)})
				end)

				dropHeader.MouseLeave:Connect(function()
					tween(dropFrame, 0.18, {BackgroundColor3 = Color3.fromRGB(30, 30, 33)})
				end)

				dropHeader.MouseButton1Click:Connect(function()
					ToggleDrop()
				end)

				Dropdown:Refresh(list, false)
				if def then
					Dropdown:Set(def)
				end
				return Dropdown
			end

			return elementHandler
		end

