local function tween(obj, t, props)
	TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props):Play()
end

local function tweenSpring(obj, t, props)
	TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Back, Enum.EasingDirection.Out), props):Play()
end

local function tweenLinear(obj, t, props)
	TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Linear), props):Play()
end

local function updateCanvasSize(scroll, list, padding)
	local size = list.AbsoluteContentSize
	size = size + Vector2.new(0, padding.PaddingBottom.Offset + padding.PaddingTop.Offset)
	scroll.CanvasSize = UDim2.new(0, size.X, 0, size.Y)
end

local function ripple(parent, x, y)
	local rip = Instance.new("Frame")
	rip.Name = "ripple"
	rip.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	rip.BackgroundTransparency = 0.85
	rip.BorderSizePixel = 0
	rip.AnchorPoint = Vector2.new(0.5, 0.5)
	rip.Size = UDim2.fromOffset(0, 0)
	rip.Position = UDim2.new(0, x - parent.AbsolutePosition.X, 0, y - parent.AbsolutePosition.Y)
	rip.ZIndex = parent.ZIndex + 5
	rip.ClipsDescendants = false

	local rc = Instance.new("UICorner")
	rc.CornerRadius = UDim.new(1, 0)
	rc.Parent = rip
	rip.Parent = parent

	local sz = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2.2
	tween(rip, 0.45, {Size = UDim2.fromOffset(sz, sz), BackgroundTransparency = 1})
	game:GetService("Debris"):AddItem(rip, 0.5)
end

