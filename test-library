		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			local absPos = main.AbsolutePosition
			dragOffX = input.Position.X - absPos.X
			dragOffY = input.Position.Y - absPos.Y
		end
	end)

	topBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if not dragging then return end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
		local screenSize = arizon.AbsoluteSize
		local mw = main.AbsoluteSize.X
		local mh = main.AbsoluteSize.Y
		local rawX = input.Position.X - dragOffX
		local rawY = input.Position.Y - dragOffY
		local clampedX = math.clamp(rawX, 0, screenSize.X - mw)
		local clampedY = math.clamp(rawY, 0, screenSize.Y - mh)
		local finalX = clampedX + mw * main.AnchorPoint.X
		local finalY = clampedY + mh * main.AnchorPoint.Y
		main.Position = UDim2.fromOffset(finalX, finalY)
		shadow.Position = UDim2.fromOffset(finalX, finalY)
	end)

