				knobCorner.CornerRadius = UDim.new(1, 0)
				knobCorner.Parent = knob
				knob.Parent = trackBg

				trackBg.Parent = sliderFrame
				sliderFrame.Parent = section

				local Slider = {Value = start}
				local isDragging = false

				local function updateSlider(inputX)
					local rel = math.clamp((inputX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
					local range = max - min
					local raw = min + rel * range
					local snapped = math.round(raw / inc) * inc
					snapped = math.clamp(snapped, min, max)
					local scale = (snapped - min) / range
					tween(trackFill, 0.05, {Size = UDim2.new(scale, 0, 1, 0)})
					tween(knob, 0.05, {Position = UDim2.new(scale, 0, 0.5, 0)})
					valueLabel.Text = tostring(snapped)
					Slider.Value = snapped
					callback(snapped)
				end

				trackBg.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						isDragging = true
						updateSlider(input.Position.X)
						tween(knob, 0.15, {Size = UDim2.fromOffset(12, 12)})
					end
				end)

				trackBg.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						isDragging = false
						tween(knob, 0.15, {Size = UDim2.fromOffset(10, 10)})
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						updateSlider(input.Position.X)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						isDragging = false
						tween(knob, 0.15, {Size = UDim2.fromOffset(10, 10)})
					end
				end)

				sliderFrame.MouseEnter:Connect(function()
					tween(sliderFrame, 0.18, {BackgroundColor3 = Color3.fromRGB(34, 34, 38)})
					tween(sliderStroke, 0.18, {Color = Color3.fromRGB(60, 60, 70)})
				end)

				sliderFrame.MouseLeave:Connect(function()
					tween(sliderFrame, 0.18, {BackgroundColor3 = Color3.fromRGB(30, 30, 33)})
					tween(sliderStroke, 0.18, {Color = Color3.fromRGB(45, 45, 52)})
				end)

				function Slider:Set(val)
					val = math.clamp(val, min, max)
					local scale = (val - min) / (max - min)
					tween(trackFill, 0.15, {Size = UDim2.new(scale, 0, 1, 0)})
					tween(knob, 0.15, {Position = UDim2.new(scale, 0, 0.5, 0)})
					valueLabel.Text = tostring(val)
					Slider.Value = val
					callback(val)
				end

				Slider:Set(start)
				return Slider
			end

